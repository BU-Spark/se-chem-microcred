```mermaid
graph LR
  %% Color schemes
  classDef studentModule fill:#E3F2FD,stroke:#1E88E5,color:#0D47A1,font-weight:600;
  classDef instructorModule fill:#E8F5E9,stroke:#43A047,color:#1B5E20,font-weight:600;
  classDef taModule fill:#FFF8E1,stroke:#F9A825,color:#F57F17,font-weight:600;
  classDef platformModule fill:#FFE0B2,stroke:#FB8C00,color:#E65100,font-weight:600;
  classDef dataModule fill:#E0F7FA,stroke:#00838F,color:#006064,font-weight:600;
  classDef integrationModule fill:#F3E5F5,stroke:#8E24AA,color:#4A148C,font-weight:600;

  %% Student Experience
  subgraph StudentExp["Student Experience"]
    SProfile["Profile & Sign-In"]:::studentModule
    SLesson["Lesson Planner"]:::studentModule
    SVideo["Video + Checkpoints"]:::studentModule
    SBadges["Badge Wallet"]:::studentModule
  end
  style StudentExp fill:#EAF3FF,stroke:#1E88E5,color:#0D47A1

  %% Instructor Experience
  subgraph InstructorExp["Instructor Experience"]
    IWorkspace["Instructor Dashboard"]:::instructorModule
    IRoster["Roster & Scheduling"]:::instructorModule
    IFeedback["Feedback & Rubrics"]:::instructorModule
  end
  style InstructorExp fill:#E9F7EE,stroke:#43A047,color:#1B5E20

  %% TA Experience
  subgraph TAExp["TA Experience"]
    TAConsole["TA Console"]:::taModule
    TAStatus["Lab Status"]:::taModule
    TAIssue["Issue Reporting"]:::taModule
  end
  style TAExp fill:#FFF5D7,stroke:#F9A825,color:#F57F17

  %% Platform Services
  subgraph Platform["ChemSkills Platform Services"]
    AuthService["Auth & Session"]:::platformModule
    LessonService["Lesson & Media API"]:::platformModule
    ProgressService["Progress Aggregation"]:::platformModule
    FeedbackService["Feedback API"]:::platformModule
  end
  style Platform fill:#FFE7C2,stroke:#FB8C00,color:#E65100

  %% Data Hub
  subgraph DataHub["Demo Data Hub"]
    StudentData["Student Records"]:::dataModule
    LessonData["Lessons & Checkpoints"]:::dataModule
    BadgeData["Badges & Analytics"]:::dataModule
  end
  style DataHub fill:#E0F2F1,stroke:#00838F,color:#006064

  %% Integrations
  subgraph Integrations["Integrations (Current & Future)"]
    YouTube["YouTube Streaming"]:::integrationModule
    Mux["Mux Uploads (future)"]:::integrationModule
    Clerk["Clerk Identity (future)"]:::integrationModule
    SIS["Campus SIS Exports (future)"]:::integrationModule
  end
  style Integrations fill:#F8EAF6,stroke:#8E24AA,color:#4A148C

  %% Student connections
  SProfile --> AuthService
  SLesson --> LessonService
  SVideo --> LessonService
  SVideo --> ProgressService
  SBadges --> ProgressService

  %% Instructor connections
  IWorkspace --> AuthService
  IRoster --> ProgressService
  IFeedback --> FeedbackService

  %% TA connections
  TAConsole --> AuthService
  TAStatus --> ProgressService
  TAIssue --> FeedbackService

  %% Platform to data hub
  AuthService --> StudentData
  LessonService --> LessonData
  ProgressService --> BadgeData
  FeedbackService --> LessonData

  %% Platform to integrations
  LessonService --> YouTube
  LessonService --> Mux
  AuthService --> Clerk
  ProgressService --> SIS
```
