```mermaid
flowchart TD
  classDef clientLayer fill:#E3F2FD,stroke:#1976D2,color:#0D47A1,font-weight:600;
  classDef serverLayer fill:#EDE7F6,stroke:#7E57C2,color:#311B92,font-weight:600;
  classDef dataLayer fill:#E8F5E9,stroke:#388E3C,color:#1B5E20,font-weight:600;
  classDef integrationLayer fill:#FFF3E0,stroke:#F57C00,color:#E65100,font-weight:600;

  %% =========================
  %% Client Layer
  subgraph Client["Client Layer (Next.js App Router + React 19)"]
    Layout["Root Layout\napp/layout.tsx"]
    Dashboard["Dashboard\napp/page.tsx"]
    LessonPage["Lesson Detail\napp/lessons/[lessonId]/page.tsx"]
    VideoPage["Lesson Video Flow\napp/lessons/[lessonId]/video.tsx"]
    AuthPages["Sign In / Sign Up\napp/(auth)/*"]
    HookAuth["useAuth Hook\n(localStorage session)"]
    HookStudent["useStudentData Hook\n(fetch + memoize DTO)"]
    YoutubePlayer["YoutubePlayer Component\napp/components/VideoPlayer/YoutubePlayer.tsx"]
  end
  class Layout,Dashboard,LessonPage,VideoPage,AuthPages,HookAuth,HookStudent,YoutubePlayer clientLayer;

  %% =========================
  %% Server Layer
  subgraph Server["Server Layer (Next.js Route Handlers)"]
    Middleware["middleware.ts\n(auth-ready pass-through)"]
    StudentAPI["GET /api/demo/student\naggregate Prisma query"]
    PlaceholderAPIs["Placeholder Endpoints\n/api/attempts, /api/progress, /api/uploads, /api/webhooks"]
  end
  class Middleware,StudentAPI,PlaceholderAPIs serverLayer;

  %% =========================
  %% Data Platform
  subgraph Data["Data Platform (Prisma + PostgreSQL)"]
    PrismaClient["Prisma Client\nlib/prisma.ts"]
    PrismaSchema["Prisma Schema\nUser, Lesson, Checkpoint, Badge, Progress, Survey, Analytics"]
    SeedScript["Seed Script\nprisma/seed.js"]
    Postgres["PostgreSQL\n(DATABASE_URL / DIRECT_DATABASE_URL)"]
  end
  class PrismaClient,PrismaSchema,SeedScript,Postgres dataLayer;

  %% =========================
  %% External Services
  subgraph Integrations["External Services (Current + Planned)"]
    YouTube["YouTube Iframe API\nlive video playback"]
    Mux["Mux Upload/Webhooks\n(future)"]
    Clerk["Clerk Identity\n(future)"]
    SIS["Institutional SIS\n(future exports)"]
  end
  class YouTube,Mux,Clerk,SIS integrationLayer;

  %% =========================
  %% Client wiring
  Layout --> Dashboard
  Layout --> LessonPage
  Layout --> VideoPage
  Layout --> AuthPages

  Dashboard --> HookAuth
  LessonPage --> HookAuth
  VideoPage --> HookAuth
  AuthPages --> HookAuth
  VideoPage --> HookStudent
  LessonPage --> HookStudent
  Dashboard --> HookStudent
  VideoPage --> YoutubePlayer

  %% =========================
  %% Client -> Server requests
  HookStudent -->|fetch JSON DTO| StudentAPI
  PlaceholderAPIs <--> |mocked progress calls| VideoPage
  Middleware -->|edge pass-through| StudentAPI
  Middleware --> PlaceholderAPIs

  %% =========================
  %% Server -> Data interactions
  StudentAPI --> PrismaClient
  PlaceholderAPIs --> PrismaClient
  PrismaClient --> PrismaSchema
  PrismaSchema --> Postgres
  SeedScript -->|npm run db:seed| Postgres

  %% =========================
  %% External integrations
  YoutubePlayer -->|Iframe API| YouTube
  PlaceholderAPIs -->|planned| Mux
  AuthPages -->|planned| Clerk
  Server -->|planned exports| SIS
```
