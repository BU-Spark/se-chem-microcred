generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(cuid())
  email               String?              @unique
  name                String?
  buid                String?              @unique
  gender              String?
  raceEthnicity       String?
  parentalEducation   String?
  pellGrantQualified  Boolean?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  enrollments         Enrollment[]
  badgeProgress       StudentBadge[]
  lessonProgress      LessonProgress[]
  checkpointResponses CheckpointResponse[]
  avatar              AvatarSetting?
  surveyResponses     SurveyResponse[]
  analytics           StudentAnalytics?
  checkpointAttempts  CheckpointAttempt[]
  createdCourses      Course[]             @relation("CourseCreator")
  createdBadges       Badge[]              @relation("BadgeCreator")
  assessmentAttempts  AssessmentAttempt[]  @relation("AssessmentStudent")
  assessmentsGiven    AssessmentAttempt[]  @relation("AssessmentAssessor")
  receivedMessages    Message[]            @relation("MessageRecipient")
  sentMessages        Message[]            @relation("MessageSender")

  @@map("Student")
}

model Message {
  id          String    @id @default(cuid())
  recipientId String
  senderId    String?
  courseId    String?
  badgeId     String?
  subject     String
  body        String
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  recipient User    @relation("MessageRecipient", fields: [recipientId], references: [id])
  sender    User?   @relation("MessageSender", fields: [senderId], references: [id])
  course    Course? @relation(fields: [courseId], references: [id])
  badge     Badge?  @relation(fields: [badgeId], references: [id])

  @@index([recipientId, createdAt])
  @@index([badgeId])
}

model AvatarSetting {
  id        String           @id @default(cuid())
  studentId String           @unique
  base      AvatarBase
  face      AvatarFace
  accessory AvatarAccessory?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  student User @relation(fields: [studentId], references: [id])
}

enum AvatarBase {
  RUBY
  EMERALD
  SAPPHIRE
  AMETHYST
}

enum AvatarFace {
  SMILE
  SURPRISED
  MISCHIEF
}

enum AvatarAccessory {
  LEAF
  FEDORA
  PROPELLER
  NONE
}

model Course {
  id           String   @id @default(cuid())
  code         String?  @unique
  assessorCode String?  @unique
  title        String
  section      String?
  sectionCount Int
  description  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdById String?
  createdBy   User?   @relation("CourseCreator", fields: [createdById], references: [id])

  enrollments Enrollment[]
  lessons     Lesson[]
  contacts    CourseContact[]
  settings    CourseSettings?
  assessments AssessmentAttempt[]
  messages    Message[]
}

model CourseSettings {
  id                    String   @id @default(cuid())
  courseId              String   @unique
  allowCooldownOverride Boolean  @default(false)
  allowAssessorMessages Boolean  @default(false)
  allowCrossSectionView Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  course Course @relation(fields: [courseId], references: [id])
}

model CourseContact {
  id        String            @id @default(cuid())
  courseId  String
  type      CourseContactType
  name      String
  email     String
  avatarUrl String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  course Course @relation(fields: [courseId], references: [id])
}

enum CourseContactType {
  INSTRUCTOR
  CHECKER
}

model Enrollment {
  id        String           @id @default(cuid())
  studentId String
  courseId  String
  role      CourseRole       @default(STUDENT)
  status    EnrollmentStatus @default(ACTIVE)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  student  User                @relation(fields: [studentId], references: [id])
  course   Course              @relation(fields: [courseId], references: [id])
  sections EnrollmentSection[]

  @@unique([studentId, courseId])
  @@index([courseId])
  @@index([role, courseId])
  @@index([courseId, role, status])
}

model EnrollmentSection {
  id           String   @id @default(cuid())
  enrollmentId String
  section      String
  createdAt    DateTime @default(now())

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, section])
}

enum CourseRole {
  STUDENT
  INSTRUCTOR
  CHECKER
}

enum EnrollmentStatus {
  PENDING
  ACTIVE
}

model Lesson {
  id                String             @id @default(cuid())
  courseId          String
  slug              String             @unique
  title             String
  summary           String
  description       String?
  thumbnailUrl      String?
  estimatedMinutes  Int?
  dueDate           DateTime?
  passingPercent    Int                @default(70)
  sortOrder         Int                @default(0)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  course            Course             @relation(fields: [courseId], references: [id])
  segments          LessonSegment[]
  checkpoints       LessonCheckpoint[]
  skills            LessonSkill[]
  badgeRequirements BadgeRequirement[] @relation("BadgeLessonRequirement")
  progress          LessonProgress[]
  surveys           SurveyPrompt[]

  @@index([courseId])
}

model LessonSkill {
  id        String @id @default(cuid())
  lessonId  String
  sortOrder Int
  text      String

  lesson Lesson @relation(fields: [lessonId], references: [id])

  @@unique([lessonId, sortOrder])
}

model LessonSegment {
  id            String   @id @default(cuid())
  lessonId      String
  sortOrder     Int
  title         String
  summary       String?
  duration      Int?
  videoUrl      String?
  muxPlaybackId String?
  thumbnailUrl  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  lesson          Lesson             @relation(fields: [lessonId], references: [id])
  checkpoints     LessonCheckpoint[]
  segmentProgress SegmentProgress[]

  @@unique([lessonId, sortOrder])
}

model LessonCheckpoint {
  id                String   @id @default(cuid())
  lessonId          String
  segmentId         String?
  sortOrder         Int
  title             String
  description       String?
  label             String?
  meta              String?
  questionCount     Int
  timeOffsetSeconds Int      @default(0)
  snapshotUrl       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  lesson    Lesson               @relation(fields: [lessonId], references: [id])
  segment   LessonSegment?       @relation(fields: [segmentId], references: [id])
  questions CheckpointQuestion[]
  responses CheckpointResponse[]
  attempts  CheckpointAttempt[]

  @@unique([lessonId, sortOrder])
  @@index([segmentId])
}

model CheckpointQuestion {
  id           String   @id @default(cuid())
  checkpointId String
  sortOrder    Int
  prompt       String
  options      Json
  correctIndex Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  checkpoint LessonCheckpoint     @relation(fields: [checkpointId], references: [id])
  responses  CheckpointResponse[]

  @@unique([checkpointId, sortOrder])
}

model LessonProgress {
  id               String       @id @default(cuid())
  studentId        String
  lessonId         String
  status           LessonStatus @default(NOT_STARTED)
  startedAt        DateTime?
  completedAt      DateTime?
  percentComplete  Int          @default(0)
  lastGradePercent Float?
  lastGradePassed  Boolean?
  lastGradedAt     DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  student            User                 @relation(fields: [studentId], references: [id])
  lesson             Lesson               @relation(fields: [lessonId], references: [id])
  segments           SegmentProgress[]
  responses          CheckpointResponse[]
  checkpointAttempts CheckpointAttempt[]

  @@unique([studentId, lessonId])
}

enum LessonStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

model SegmentProgress {
  id               String        @id @default(cuid())
  lessonProgressId String
  segmentId        String
  status           SegmentStatus @default(NOT_STARTED)
  startedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  lessonProgress LessonProgress @relation(fields: [lessonProgressId], references: [id])
  segment        LessonSegment  @relation(fields: [segmentId], references: [id])

  @@unique([lessonProgressId, segmentId])
}

enum SegmentStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

model CheckpointResponse {
  id               String   @id @default(cuid())
  attemptId        String?
  checkpointId     String
  questionId       String?
  studentId        String
  lessonProgressId String?
  selectedIndex    Int?
  isCorrect        Boolean?
  createdAt        DateTime @default(now())

  attempt        CheckpointAttempt?  @relation(fields: [attemptId], references: [id])
  checkpoint     LessonCheckpoint    @relation(fields: [checkpointId], references: [id])
  question       CheckpointQuestion? @relation(fields: [questionId], references: [id])
  student        User                @relation(fields: [studentId], references: [id])
  lessonProgress LessonProgress?     @relation(fields: [lessonProgressId], references: [id])
}

model CheckpointAttempt {
  id               String    @id @default(cuid())
  checkpointId     String
  userId           String
  lessonProgressId String?
  startedAt        DateTime  @default(now())
  completedAt      DateTime?
  isPassing        Boolean?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  checkpoint     LessonCheckpoint     @relation(fields: [checkpointId], references: [id])
  user           User                 @relation(fields: [userId], references: [id])
  lessonProgress LessonProgress?      @relation(fields: [lessonProgressId], references: [id])
  responses      CheckpointResponse[]
}

model Badge {
  id              String             @id @default(cuid())
  slug            String             @unique
  name            String
  description     String?
  category        BadgeCategory?
  createdById     String?
  sourceBadgeId   String?
  availableOn     DateTime?
  closesOn        DateTime?
  neverCloses     Boolean?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  createdBy       User?              @relation("BadgeCreator", fields: [createdById], references: [id], onDelete: SetNull)
  sourceBadge     Badge?             @relation("BadgeSource", fields: [sourceBadgeId], references: [id], onDelete: SetNull)
  importedCopies  Badge[]            @relation("BadgeSource")
  requirements    BadgeRequirement[]
  studentProgress StudentBadge[]
  surveys         SurveyPrompt[]
  assessments     AssessmentAttempt[]
  messages        Message[]

  @@index([createdById])
  @@index([sourceBadgeId])
}

enum BadgeCategory {
  SAFETY
  EQUIPMENT
  WASTE
  OTHER
}

model BadgeRequirement {
  id        String   @id @default(cuid())
  badgeId   String
  lessonId  String?
  summary   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  badge  Badge   @relation(fields: [badgeId], references: [id])
  lesson Lesson? @relation("BadgeLessonRequirement", fields: [lessonId], references: [id])

  @@index([badgeId])
  @@index([lessonId])
}

model StudentBadge {
  id        String      @id @default(cuid())
  studentId String
  badgeId   String
  status    BadgeStatus @default(LEARNING)
  awardedAt DateTime?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  score     Int?
  reassessmentLimit    Int?
  cooldownDays         Int?
  reassessmentRequired Boolean?

  student User  @relation(fields: [studentId], references: [id])
  badge   Badge @relation(fields: [badgeId], references: [id])

  @@unique([studentId, badgeId])
  @@index([badgeId])
  @@index([status, badgeId])
}

model StudentAnalytics {
  id                       String   @id @default(cuid())
  studentId                String   @unique
  hoursLearning            Int      @default(0)
  badgesCompleted          Int      @default(0)
  badgesReadyForAssessment Int      @default(0)
  badgesNotAttempted       Int      @default(0)
  questionsAnswered        Int      @default(0)
  averageAssessmentScore   Int      @default(0)
  highestAssessmentScore   Int      @default(0)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  student User @relation(fields: [studentId], references: [id])
}

model AssessmentAttempt {
  id          String    @id @default(cuid())
  courseId    String
  badgeId     String
  studentId   String
  assessorId  String
  passed      Boolean
  score       Int?
  feedback    String?
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  course    Course                       @relation(fields: [courseId], references: [id])
  badge     Badge                        @relation(fields: [badgeId], references: [id])
  student   User                         @relation("AssessmentStudent", fields: [studentId], references: [id])
  assessor  User                         @relation("AssessmentAssessor", fields: [assessorId], references: [id])
  responses AssessmentCriterionResponse[]

  @@index([courseId, badgeId])
  @@index([studentId, badgeId])
  @@index([assessorId])
  @@index([completedAt])
}

model AssessmentCriterionResponse {
  id             String   @id @default(cuid())
  attemptId      String
  criterionKey   String
  criterion      String
  selectedOption String?
  notes          String?
  passed         Boolean?
  sortOrder      Int
  createdAt      DateTime @default(now())

  attempt AssessmentAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@index([attemptId])
}

enum BadgeStatus {
  LEARNING
  READY_FOR_ASSESSMENT
  READY_FOR_FINALIZATION
  COMPLETED
}

model SurveyPrompt {
  id        String        @id @default(cuid())
  context   SurveyContext
  lessonId  String?
  badgeId   String?
  question  String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  lesson    Lesson?          @relation(fields: [lessonId], references: [id])
  badge     Badge?           @relation(fields: [badgeId], references: [id])
  responses SurveyResponse[]
}

model SurveyResponse {
  id          String   @id @default(cuid())
  promptId    String
  studentId   String
  rating      Int
  comment     String?
  submittedAt DateTime @default(now())

  prompt  SurveyPrompt @relation(fields: [promptId], references: [id])
  student User         @relation(fields: [studentId], references: [id])
}

enum SurveyContext {
  LESSON
  BADGE
}
