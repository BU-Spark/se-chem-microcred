generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  name          String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  quizAttempts  QuizAttempt[]
  skillAttempts SkillAttempt[]
  badges        IssuedBadge[]
}

model Course {
  id          String    @id @default(cuid())
  title       String
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  sections    Section[]
}

model Section {
  id        String   @id @default(cuid())
  title     String
  order     Int      @default(0)
  course    Course   @relation(fields: [courseId], references: [id])
  courseId  String
  skills    Skill[]
}

model Skill {
  id            String        @id @default(cuid())
  title         String
  description   String?
  order         Int           @default(0)
  section       Section       @relation(fields: [sectionId], references: [id])
  sectionId     String
  rubricItems   RubricItem[]
  video         Video?
  qevQuestions  QEVQuestion[]
  quiz          Quiz?
  quizAttempts  QuizAttempt[]
  skillAttempts SkillAttempt[]
  badges        IssuedBadge[]
}

model RubricItem {
  id        String @id @default(cuid())
  label     String
  skill     Skill  @relation(fields: [skillId], references: [id])
  skillId   String
  threshold Int    @default(0)
}

model Video {
  id            String @id @default(cuid())
  skill         Skill  @relation(fields: [skillId], references: [id])
  skillId       String @unique
  muxAssetId    String?
  muxPlaybackId String?
}

model QEVQuestion {
  id        String @id @default(cuid())
  skill     Skill  @relation(fields: [skillId], references: [id])
  skillId   String
  prompt    String
  startTime Int
  endTime   Int
}

model Quiz {
  id        String        @id @default(cuid())
  skill     Skill         @relation(fields: [skillId], references: [id])
  skillId   String @unique
  title     String
  questions Json
  attempts  QuizAttempt[]
}

model QuizAttempt {
  id        String   @id @default(cuid())
  quiz      Quiz     @relation(fields: [quizId], references: [id])
  quizId    String
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  score     Float?
  status    String
  startedAt DateTime @default(now())
  submittedAt DateTime?
  answers   Json?
}

model SkillAttempt {
  id        String   @id @default(cuid())
  skill     Skill    @relation(fields: [skillId], references: [id])
  skillId   String
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  status    String
  createdAt DateTime @default(now())
}

model IssuedBadge {
  id        String   @id @default(cuid())
  skill     Skill    @relation(fields: [skillId], references: [id])
  skillId   String
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  issuedAt  DateTime @default(now())
  metadata  Json?
}
