{
  "name": "template-next-js",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20 <23",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "postinstall": "prisma generate",
    "railway:build": "prisma generate && npm run build",
    "railway:start": "npx prisma migrate deploy && npm run start",
    "lint": "eslint . --fix",
    "lint:debug": "eslint . --fix --debug",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepare": "husky",
    "db:seed": "prisma db seed",
    "db:seed-user": "node prisma/seed-user.js"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.35.5",
    "@iconify/react": "^6.0.2",
    "@lexical/react": "^0.46.0",
    "@prisma/client": "^6.17.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.25",
    "json-to-csv-export": "^3.1.3",
    "lexical": "^0.46.0",
    "next": "^15.3.2",
    "prisma": "^6.17.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "svix": "^1.37.0",
    "swr": "^2.4.2"
  },
  "devDependencies": {
    "@eslint/compat": "^1.2.9",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.19.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.22.0",
    "@typescript-eslint/parser": "^8.22.0",
    "eslint": "^9.19.0",
    "eslint-config-next": "15.1.6",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.3",
    "eslint-plugin-react": "^7.37.4",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^15.4.3",
    "prettier": "3.4.2",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "typescript-eslint": "^8.22.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
